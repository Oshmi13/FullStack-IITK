<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <hr color="orange" />
    <h1 align="center"> EJS Contact US Page</h1>
    <hr color="green" />

    <% let count = 1  %>

    <% while(count <= 10)  { %>
    
        <%= count*num %>
        <% count = count + 1 %>
    <% } %>

    <hr />
    

    <table border="2">
        <thead>
            <tr>
                <th> Number </th>
                <th> Table of Number </th>
            </tr>
        </thead>
        <tbody>
        <% count = 1; %>
        <% while(count <= 10) { %>
        
        <tr>
            <td><%= count; %></td>
            <td><%= count*num; %></td>
        </tr>

        <% count++; %>
        <% } %>

        </tbody>
    </table>

</body>
</html>

